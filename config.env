# ─── Version Configuration ──────────────────────────────────────────────────
RENPY_VERSION   = 8.0.3
RENPY_TAG       = 8.0.3.22090809
RENPY_BUILD_TAG = renpy-8.0.3.22090809
PYGAME_SDL2_TAG = renpy-8.0.3.22090809

# ─── Source Repositories ────────────────────────────────────────────────────
RENPY_REPO       = https://github.com/renpy/renpy.git
RENPY_BUILD_REPO = https://github.com/renpy/renpy-build.git
PYGAME_SDL2_REPO = https://github.com/renpy/pygame_sdl2.git

# ─── Build targets ─────────────────────────────────────────────────────────
# Comma-separated lists, passed to renpy-build's build.py
# Available platforms: linux, windows, mac, android, ios, web
# Available archs:     x86_64, i686, armv7l, arm64_v8a, armeabi_v7a, arm64, sim-x86_64, sim-arm64, wasm
# Available pythons:   2
#
# Leave empty for "all applicable".
BUILD_PLATFORMS = linux,android
BUILD_ARCHS     = x86_64,i686,arm64_v8a,armeabi_v7a
BUILD_PYTHONS   = 3

# ─── Toolchain Tarballs ────────────────────────────────────────────────────
# Large files not tracked in git. Downloaded into work/renpy-build/tars/.
# To add a tarball: 1) add filename to TARS_<platform>, 2) add URL.<filename>.
#
# Android
TARS_ANDROID = android-ndk-r21d-linux-x86_64.zip
URL.android-ndk-r21d-linux-x86_64.zip = https://dl.google.com/android/repository/android-ndk-r21d-linux-x86_64.zip
#
# Linux cross-compilation
TARS_LINUX = binutils-2.33.1.tar.gz gcc-9.2.0.tar.gz
URL.binutils-2.33.1.tar.gz = https://ftpmirror.gnu.org/binutils/binutils-2.33.1.tar.gz
URL.gcc-9.2.0.tar.gz      = https://ftpmirror.gnu.org/gcc/gcc-9.2.0/gcc-9.2.0.tar.gz

# ─── System Packages (apt) ────────────────────────────────────────────────
# Installed once via `make prepare`. Adjust for your distro if needed.
#
# Core build tools
PREPARE_PKGS  = git build-essential ccache curl unzip \
                python3-dev python3-venv python3-pip \
                autoconf automake libtool pkg-config autoconf-archive \
                libssl-dev libbz2-dev libgmp-dev libmpfr-dev libmpc-dev
# Host build deps (SDL2, media, etc.)
PREPARE_PKGS += libsdl2-dev libsdl2-image-dev libsdl2-ttf-dev libsdl2-mixer-dev \
                libavcodec-dev libavformat-dev libswresample-dev libswscale-dev \
                libfreetype6-dev libfribidi-dev libpng-dev zlib1g-dev libjpeg-dev \
                nasm
# Linux cross-compilation sysroot
PREPARE_PKGS_LINUX = debootstrap

# ─── Python venv packages (pip) ────────────────────────────────────────────
# Installed into a build-local virtualenv.
PIP_PACKAGES = Cython==0.29.37 Jinja2
