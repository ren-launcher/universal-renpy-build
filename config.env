# ─── Version Configuration ──────────────────────────────────────────────────
RENPY_VERSION   = 8.4.1
RENPY_TAG       = 8.4.1.25072401
RENPY_BUILD_TAG = renpy-8.4.1.25072401
PYGAME_SDL2_TAG = renpy-8.4.1.25072401

# ─── Source Repositories ────────────────────────────────────────────────────
RENPY_REPO       = https://github.com/renpy/renpy.git
RENPY_BUILD_REPO = https://github.com/renpy/renpy-build.git
PYGAME_SDL2_REPO = https://github.com/renpy/pygame_sdl2.git

# ─── Build targets ─────────────────────────────────────────────────────────
# Comma-separated lists, passed to renpy-build's build.py
# Available platforms: linux, windows, mac, android, ios, web
# Available archs:     x86_64, i686, armv7l, arm64_v8a, armeabi_v7a, arm64, sim-x86_64, sim-arm64, wasm
# Available pythons:   2
#
# Leave empty for "all applicable".
BUILD_PLATFORMS = linux,android
BUILD_ARCHS     = x86_64,i686,arm64_v8a,armeabi_v7a
BUILD_PYTHONS   = 3

# ─── Toolchain Tarballs ────────────────────────────────────────────────────
# Large files not tracked in git. Downloaded into work/renpy-build/tars/.
# To add a tarball: 1) add filename to TARS_<platform>, 2) add URL.<filename>.
#
# Android (renpy-build 8.1 expects r25c)
TARS_ANDROID = android-ndk-r25c-linux.zip
URL.android-ndk-r25c-linux.zip = https://dl.google.com/android/repository/android-ndk-r25c-linux.zip
#
# Linux cross-compilation
TARS_LINUX = binutils-2.33.1.tar.gz gcc-9.2.0.tar.gz
URL.binutils-2.33.1.tar.gz = https://ftpmirror.gnu.org/binutils/binutils-2.33.1.tar.gz
URL.gcc-9.2.0.tar.gz      = https://ftpmirror.gnu.org/gcc/gcc-9.2.0/gcc-9.2.0.tar.gz

# Dependency installation is delegated to upstream renpy-build/prepare.sh.
